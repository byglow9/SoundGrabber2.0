# yt-dlp authentication for YouTube (Phase 1 - Processing Pipeline)
# Generate cookies.txt using a browser extension like "Get cookies.txt LOCALLY"
# Required: cookies.txt MUST have chmod 600 and MUST NOT be committed.
YTDLP_COOKIES_FILE=./cookies.txt

# PO Token for YouTube GVS streaming. Format: web.gvs+TOKEN (the prefix is added by pipeline.py).
# Rotate every 24-48h or when downloads start failing with "Sign in to confirm you're not a bot".
YTDLP_PO_TOKEN=
