# SoundGrabber — .env template for docker-compose local deploy (Phase 13).
# Copy this to .env (which is .dockerignore + .gitignore'd) and adjust values.
# Notebook é ambiente privado: Redis e bgutil não são expostos ao host.
# Nunca publique este arquivo preenchido com valores reais.

# Redis
# Gere com: openssl rand -base64 32
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# Produção deve ficar false. Use true apenas em desenvolvimento local fora do compose.
DEV_MODE=false

# bgutil PO Token provider INATIVO no notebook (D-09) — IP residencial usa apenas cookies; setar http://bgutil:4416 apenas como Plano B se E2E falhar com LOGIN_REQUIRED (D-10)
BGUTIL_BASE_URL=

# yt-dlp cache + cookies — Phase 14 D-02; bind mount :ro no docker-compose.yml lê do host
YTDLP_CACHE_DIR=/data/yt-dlp-cache

# Rate limiting (defaults conservadores)
RATE_LIMIT_PER_MINUTE=3
JOB_POLL_RATE_LIMIT_PER_MINUTE=60
FILE_DOWNLOAD_RATE_LIMIT_PER_MINUTE=10

# Trust CF-Connecting-IP only from local/Docker proxy peers.
# Keep the app bound to 127.0.0.1 in docker-compose.yml.
TRUSTED_PROXY_IPS=127.0.0.1,::1,172.16.0.0/12

# WAV file lifecycle
WAV_TTL_SECONDS=900
JOB_TTL_SECONDS=3600

# Som da Semana operator panel (Phase 11)
ADMIN_PASSWORD=change-me-locally
ADMIN_SESSION_SECRET=change-me-to-a-long-random-secret
FEATURED_FALLBACK_PATH=.data/featured-current.json
FEATURED_HISTORY_PATH=.data/featured-history.json
SYSTEM_UPDATES_PATH=.data/system-updates.json

# Deploy gate acknowledgements.
# Mude para true somente depois de configurar/validar fora do codigo.
ORIGIN_LOCKDOWN_ENABLED=false
CLOUDFLARE_ACCESS_YONKOU_ENABLED=false
SECRETS_ROTATED_AFTER_AUDIT=false
MONITORING_ENABLED=false
BACKUP_ENCRYPTED_OFF_GIT=false

# Opcional: use apenas para deploy emergencial e documente o motivo.
ALLOW_DIRTY_DEPLOY=false
